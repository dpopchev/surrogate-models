# Example configuration file for surrogate_models.
#
# Copy to `surrogate_models.toml` and adjust (the real file is gitignored). Each
# [section] is a config section; its keys are that section's fields. OS env and
# .env override these values (see .env.example); these in turn override the
# built-in defaults.
#
# Paths must be ABSOLUTE (config rejects a relative value). The built-in defaults
# are filesystem-rooted, so they resolve the same from any working directory. The
# values below mirror those defaults. TOML performs NO variable expansion: ${HOME}
# and `~` are taken verbatim (they would create directories literally named
# `${HOME}` / `~`), so write full literal paths here -- or set ${HOME}-based paths
# in `.env`, which does expand them.

[datasets]
# Where the datasets bounded context persists datasets (parquet).
path = "/var/data/surrogate_models/datasets"
# Raw concatenated neutron-stars .dat file the ingest reader digests.
neutron_stars_source = "/data/neutron-stars/neutron-stars.dat"
